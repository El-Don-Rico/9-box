generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  MANAGER
  AREA_LEAD
  LEADERSHIP
  ADMIN
}

enum CycleStatus {
  OPEN
  CLOSED
}

enum TrendDirection {
  IMPROVING
  STABLE
  DECLINING
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// Per-review-cycle progress status recorded against a goal.
enum GoalProgressStatus {
  ON_TRACK
  OFF_TRACK
  COMPLETE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  jobTitle     String?
  team         String?
  role         Role     @default(EMPLOYEE)
  managerId    String?
  manager      User?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports      User[]   @relation("ManagerReports")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managerAssessmentsGiven    ManagerAssessment[] @relation("AssessmentByManager")
  managerAssessmentsReceived ManagerAssessment[] @relation("AssessmentForEmployee")
  selfAssessments            SelfAssessment[]
  resources                  Resource[]
  goals                      Goal[]             @relation("EmployeeGoals")
  goalsCreated               Goal[]             @relation("GoalCreator")
  keyMetrics                 KeyMetric[]        @relation("EmployeeKeyMetrics")
  keyMetricsCreated          KeyMetric[]        @relation("KeyMetricCreator")
  goalUpdatesCreated         GoalUpdate[]       @relation("GoalUpdateCreator")
  metricResultsCreated       MetricResult[]     @relation("MetricResultCreator")
  auditLogs                  AuditLog[]         @relation("AuditActor")

  @@index([managerId])
  @@index([role])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  name      String
  jobTitle  String?
  team      String?
  role      Role     @default(EMPLOYEE)
  managerId String?
  token     String   @unique
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model AssessmentCycle {
  id        String      @id @default(cuid())
  // Legacy monthly cycles keep `month`; new quarterly cycles use `quarter` (1-4).
  // Uniqueness per period is enforced in application code so historical monthly
  // rows can coexist with quarterly ones.
  month     Int?
  quarter   Int?
  year      Int
  status    CycleStatus @default(OPEN)
  createdAt DateTime    @default(now())

  managerAssessments ManagerAssessment[]
  selfAssessments    SelfAssessment[]
  goalUpdates        GoalUpdate[]
  metricResults      MetricResult[]

  @@index([year])
}

model ManagerAssessment {
  id                  String    @id @default(cuid())
  cycleId             String
  cycle               AssessmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  managerId           String
  manager             User      @relation("AssessmentByManager", fields: [managerId], references: [id], onDelete: Cascade)
  employeeId          String
  employee            User      @relation("AssessmentForEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  performance         Int?
  performanceEvidence String?
  growthReadiness          Int?
  growthReadinessEvidence  String?
  valCustomerFirst    Int?
  valStepIntoArena    Int?
  valFlockToProblems  Int?
  valGiveEnergy       Int?
  valuesEvidence      String?
  engagement          Int?
  engagementEvidence  String?
  trend               TrendDirection?
  notes               String?
  submittedAt         DateTime?
  resultsSentAt       DateTime?
  oneOnOneComplete    Boolean   @default(false)
  oneOnOneCompletedAt DateTime?
  oneOnOneNotes       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([cycleId, managerId, employeeId])
  @@index([cycleId])
  @@index([managerId])
  @@index([employeeId])
}

model SelfAssessment {
  id                       String    @id @default(cuid())
  cycleId                  String
  cycle                    AssessmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId               String
  employee                 User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  performance              Int?
  performanceJustification String?
  achievements             String?
  blockers                 String?
  learning                 String?
  valCustomerFirst         Int?
  valStepIntoArena         Int?
  valFlockToProblems       Int?
  valGiveEnergy            Int?
  valuesReflection         String?
  engagement               Int?
  engagementDriver         String?
  supportNeeded            String?
  goalsNextMonth           String?
  submittedAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([cycleId, employeeId])
  @@index([cycleId])
  @@index([employeeId])
}

model Resource {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  content      String
  published    Boolean  @default(false)
  sortOrder    Int      @default(0)
  allowedRoles Role[]   @default([EMPLOYEE, MANAGER, AREA_LEAD, LEADERSHIP, ADMIN])
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

model Goal {
  id          String     @id @default(cuid())
  employeeId  String
  employee    User       @relation("EmployeeGoals", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User       @relation("GoalCreator", fields: [createdById], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  updates     GoalUpdate[]

  @@index([employeeId])
  @@index([createdById])
}

model KeyMetric {
  id          String  @id @default(cuid())
  employeeId  String
  employee    User    @relation("EmployeeKeyMetrics", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("KeyMetricCreator", fields: [createdById], references: [id])
  name        String
  target      String
  unit        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  results     MetricResult[]

  @@index([employeeId])
  @@index([createdById])
}

// Append-only audit trail for sensitive changes (e.g. editing a completed
// assessment before results are sent, sending results, admin password resets).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String
  summary    String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// A goal's progress recorded during a specific review cycle: an off-track /
// on-track / complete status plus a free-text update.
model GoalUpdate {
  id          String             @id @default(cuid())
  goalId      String
  goal        Goal               @relation(fields: [goalId], references: [id], onDelete: Cascade)
  cycleId     String
  cycle       AssessmentCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  status      GoalProgressStatus
  note        String?
  createdById String
  createdBy   User               @relation("GoalUpdateCreator", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([goalId, cycleId])
  @@index([goalId])
  @@index([cycleId])
}

// A key metric's actual result recorded during a specific review cycle.
model MetricResult {
  id          String          @id @default(cuid())
  keyMetricId String
  keyMetric   KeyMetric       @relation(fields: [keyMetricId], references: [id], onDelete: Cascade)
  cycleId     String
  cycle       AssessmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  actual      String
  note        String?
  createdById String
  createdBy   User            @relation("MetricResultCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([keyMetricId, cycleId])
  @@index([keyMetricId])
  @@index([cycleId])
}
