generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  MANAGER
  AREA_LEAD
  LEADERSHIP
  ADMIN
}

enum CycleStatus {
  OPEN
  CLOSED
}

enum TrendDirection {
  IMPROVING
  STABLE
  DECLINING
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MeetingType {
  ONE_ON_ONE
  PIP
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  jobTitle     String?
  team         String?
  role         Role     @default(EMPLOYEE)
  managerId    String?
  manager      User?    @relation("ManagerReports", fields: [managerId], references: [id])
  reports      User[]   @relation("ManagerReports")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managerAssessmentsGiven    ManagerAssessment[] @relation("AssessmentByManager")
  managerAssessmentsReceived ManagerAssessment[] @relation("AssessmentForEmployee")
  selfAssessments            SelfAssessment[]
  resources                  Resource[]
  goals                      Goal[]             @relation("EmployeeGoals")
  goalsCreated               Goal[]             @relation("GoalCreator")
  keyMetrics                 KeyMetric[]        @relation("EmployeeKeyMetrics")
  keyMetricsCreated          KeyMetric[]        @relation("KeyMetricCreator")
  meetingsAsEmployee         Meeting[]          @relation("MeetingEmployee")
  meetingsAsManager          Meeting[]          @relation("MeetingManager")
  tasksAssigned              Task[]             @relation("TaskAssignee")
  tasksCreated               Task[]             @relation("TaskCreator")

  @@index([managerId])
  @@index([role])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  name      String
  jobTitle  String?
  team      String?
  role      Role     @default(EMPLOYEE)
  managerId String?
  token     String   @unique
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model AssessmentCycle {
  id        String      @id @default(cuid())
  month     Int
  year      Int
  status    CycleStatus @default(OPEN)
  createdAt DateTime    @default(now())

  managerAssessments ManagerAssessment[]
  selfAssessments    SelfAssessment[]
  meetings           Meeting[]

  @@unique([month, year])
}

model ManagerAssessment {
  id                  String    @id @default(cuid())
  cycleId             String
  cycle               AssessmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  managerId           String
  manager             User      @relation("AssessmentByManager", fields: [managerId], references: [id], onDelete: Cascade)
  employeeId          String
  employee            User      @relation("AssessmentForEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  performance         Int?
  performanceEvidence String?
  growthReadiness          Int?
  growthReadinessEvidence  String?
  valCustomerFirst    Int?
  valStepIntoArena    Int?
  valFlockToProblems  Int?
  valGiveEnergy       Int?
  valuesEvidence      String?
  engagement          Int?
  engagementEvidence  String?
  trend               TrendDirection?
  notes               String?
  startedAt           DateTime?
  submittedAt         DateTime?
  resultsSentAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([cycleId, managerId, employeeId])
  @@index([cycleId])
  @@index([managerId])
  @@index([employeeId])
}

model SelfAssessment {
  id                       String    @id @default(cuid())
  cycleId                  String
  cycle                    AssessmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId               String
  employee                 User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  performance              Int?
  performanceJustification String?
  achievements             String?
  blockers                 String?
  learning                 String?
  valCustomerFirst         Int?
  valStepIntoArena         Int?
  valFlockToProblems       Int?
  valGiveEnergy            Int?
  valuesReflection         String?
  engagement               Int?
  engagementDriver         String?
  supportNeeded            String?
  goalsNextMonth           String?
  submittedAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([cycleId, employeeId])
  @@index([cycleId])
  @@index([employeeId])
}

model Resource {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  content      String
  published    Boolean  @default(false)
  sortOrder    Int      @default(0)
  allowedRoles Role[]   @default([EMPLOYEE, MANAGER, AREA_LEAD, LEADERSHIP, ADMIN])
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

model Goal {
  id          String     @id @default(cuid())
  employeeId  String
  employee    User       @relation("EmployeeGoals", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User       @relation("GoalCreator", fields: [createdById], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId])
  @@index([createdById])
}

model KeyMetric {
  id          String  @id @default(cuid())
  employeeId  String
  employee    User    @relation("EmployeeKeyMetrics", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("KeyMetricCreator", fields: [createdById], references: [id])
  name        String
  target      String
  unit        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
  @@index([createdById])
}

model Meeting {
  id          String        @id @default(cuid())
  type        MeetingType   @default(ONE_ON_ONE)
  status      MeetingStatus @default(SCHEDULED)
  employeeId  String
  employee    User          @relation("MeetingEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  managerId   String
  manager     User          @relation("MeetingManager", fields: [managerId], references: [id], onDelete: Cascade)
  cycleId     String?
  cycle       AssessmentCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tasks       Task[]

  @@index([employeeId])
  @@index([managerId])
  @@index([cycleId])
  @@index([type])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  category    String?
  assigneeId  String
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  dueDate     DateTime?
  meetingId   String?
  meeting     Meeting?   @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([assigneeId])
  @@index([createdById])
  @@index([meetingId])
  @@index([status])
}
